{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true}); try{require('node:fs').unlinkSync('tsconfig.build.tsbuildinfo')}catch{} try{require('node:fs').unlinkSync('tsconfig.tsbuildinfo')}catch{}\"",
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
