# --- PostgreSQL / Supabase (Prisma: packages/database, apps/api) ---
# Supabase: Project Settings → Database → Connection string
# - "URI" with user `postgres` works for `prisma db push` / migrate.
# - Prefer the Direct connection host (`db.<project-ref>.supabase.co:5432`) for migrations;
#   the pooler (`...pooler.supabase.com`, port 6543 transaction / 5432 session) is fine for runtime.
# - Include SSL, e.g. ?sslmode=require (often already in the dashboard URI).
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
# If you use Supabase pooler with Prisma, you may also want:
# - pgbouncer=true (transaction pooling)
# - connection_limit=5 (avoid Prisma pool starvation)
# - pool_timeout=30 (seconds)

# --- Redis cache (apps/api) ---
# Optional but recommended for speed. Example:
# REDIS_URL="redis://localhost:6379"
# Also enables the Socket.IO Redis adapter: room broadcasts (`/realtime`, `/chat`) reach all API instances.
REDIS_URL=""

# API server (apps/api)
API_PORT=4000
# Optional: OpenAPI "Server" URL in Swagger UI (defaults to http://localhost:${API_PORT})
# SWAGGER_SERVER_URL="http://localhost:4000"
# Must match the Next.js origin; used to redirect after Google OAuth (/auth/callback?access_token=…)
FRONTEND_URL="http://localhost:3000"

# Next.js web app (apps/web) — browser-exposed; points to Nest global prefix `/api`
# apps/web/next.config.js loads this file from the monorepo root so JWT_SECRET (proxy) matches the API
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# Optional: Web `/chat` Socket.IO room — UUID of a `channels` row; squad panel auto-joins when open (user must be a workspace member)
# NEXT_PUBLIC_SQUAD_CHAT_CHANNEL_ID="00000000-0000-4000-8000-000000000000"

# Auth (Nest JWT + Next.js middleware) — same secret in API and web; middleware verifies the session cookie (HS256)
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Supabase Storage (apps/api — user avatars + workspace logos via service role)
# 1) Dashboard → Storage → New bucket → name: avatars (must match SUPABASE_STORAGE_BUCKET)
# 2) For public URLs from getPublicUrl(): bucket → Configuration → Public bucket, or add a policy for SELECT
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
# Optional; default is "avatars" — create this bucket in Supabase if you see "Bucket not found"
# SUPABASE_STORAGE_BUCKET="avatars"

# Google OAuth (optional — set all three to enable GET /api/auth/google)
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client (Web application)
# Authorized redirect URI must match GOOGLE_CALLBACK_URL exactly (e.g. http://localhost:4000/api/auth/google/callback)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/auth/google/callback"

# AI
OPENAI_API_KEY="sk-..."
